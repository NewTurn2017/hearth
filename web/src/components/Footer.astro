---
interface Props { locale: 'ko' | 'en'; }
const { locale } = Astro.props;
const labels = locale === 'ko'
  ? { privacy: '개인정보처리방침', support: '지원', copyright: '© 2026 Hearth' }
  : { privacy: 'Privacy', support: 'Support', copyright: '© 2026 Hearth' };
---
<footer class="border-t border-ink/10 mt-32">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-3 px-6 py-10 text-sm text-ink/60 md:flex-row md:px-8">
    <span>{labels.copyright}</span>
    <div class="flex gap-6">
      <a href={`/${locale}/privacy`} class="hover:text-ink transition-colors">{labels.privacy}</a>
      <a href={`/${locale}/support`} class="hover:text-ink transition-colors">{labels.support}</a>
    </div>
  </div>
</footer>
