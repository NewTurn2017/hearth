---
import LocaleSwitcher from './LocaleSwitcher.astro';
interface Props { locale: 'ko' | 'en'; path: string; }
const { locale, path } = Astro.props;
const nav = locale === 'ko'
  ? [{ href: '/install/cli', label: 'CLI' }, { href: '/install/skill', label: 'Skill' }, { href: '/support', label: '지원' }]
  : [{ href: '/install/cli', label: 'CLI' }, { href: '/install/skill', label: 'Skill' }, { href: '/support', label: 'Support' }];
---
<header class="bg-ink text-paper">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4 md:px-8">
    <a href={`/${locale}/`} aria-label="Hearth home" class="font-medium text-base tracking-tight">Hearth</a>
    <nav class="flex items-center gap-5 text-sm">
      {nav.map((n) => <a href={`/${locale}${n.href}`} class="text-paper/80 hover:text-paper transition-colors">{n.label}</a>)}
      <LocaleSwitcher locale={locale} path={path} />
    </nav>
  </div>
</header>
